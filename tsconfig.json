{
  // IMPORTANT for downstream specialists: NodeNext + ESM requires explicit .js extensions
  // on all relative imports inside src/, e.g. import { foo } from "./foo.js"
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "declaration": false
  },
  "include": ["src/**/*", "tests/**/*"]
}
